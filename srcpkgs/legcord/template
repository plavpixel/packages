# Template file for 'legcord'
pkgname=legcord
version=1.1.1
revision=1
hostmakedepends="pnpm nodejs git python3 python3-devel make gcc pkg-config libnotify-devel cmake"
depends="electron35"
short_desc="Lightweight, customizable Discord client"
maintainer="Haris <plavpxl@proton.me>"
license="OSL-3.0"
homepage="https://github.com/Legcord/Legcord"
distfiles="https://github.com/Legcord/Legcord/archive/refs/tags/v${version}.tar.gz"
checksum=3b6215e28356426992f67db0bcaff992cc58779d6a3e684a284c6765a75c20f2

do_build() {
    # must match Void repos to patch package.json
    local SYSTEM_ELECTRON_VER="35.7.2"
    local SYSTEM_ELECTRON_MAJOR="35"
    sed -i "s|\"electron\": \"^35.0.2\"|\"electron\": \"${SYSTEM_ELECTRON_VER}\"|" package.json

    export npm_config_target="${SYSTEM_ELECTRON_VER}"
    export npm_config_arch=x64
    export npm_config_target_arch=x64
    export npm_config_disturl="https://electronjs.org/headers"
    export npm_config_runtime="electron"
    export npm_config_build_from_source="true"

    export ELECTRON_SKIP_BINARY_DOWNLOAD="1"

    pnpm install --frozen-lockfile
    pnpm run build
    pnpm exec electron-builder --linux --x64 --dir \
        --config.electronDist="/usr/lib/electron${SYSTEM_ELECTRON_MAJOR}" \
        --config.electronVersion="${SYSTEM_ELECTRON_VER}" \
        --config.npmRebuild="false" \
        --config.directories.output="dist"
}

do_install() {
    vmkdir usr/lib/legcord
    vcopy dist/linux-unpacked/resources/app.asar usr/lib/legcord/

    vbin "${FILESDIR}/legcord"
    vinstall "${FILESDIR}/legcord.desktop" 644 usr/share/applications

    if [ -f "build/icon.png" ]; then
        vinstall build/icon.png 644 usr/share/pixmaps/legcord.png
    else
        vinstall assets/ac_icon.png 644 usr/share/pixmaps/legcord.png
    fi
}
